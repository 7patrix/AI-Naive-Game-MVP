generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum GenerationJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UploadedAssetKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum GameEventType {
  PLAY_START
  PLAY_LOADED
  PLAY_ERROR
}

enum GameReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ApiCredentialProvider {
  OPENAI_COMPATIBLE
}

enum ApiCredentialSource {
  PLATFORM
  USER_KEY
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  passwordHash    String
  emailVerifiedAt DateTime?
  avatarUrl       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  games           Game[]
  sessions        Session[]
  uploads         UploadedAsset[]
  jobs            GenerationJob[]
  events          GameEvent[]
  likes           GameLike[]
  favorites       GameFavorite[]
  oauthAccounts   OAuthAccount[]
  reports         GameReport[]    @relation("ReporterReports")
  resolvedReports GameReport[]    @relation("ResolverReports")
  adminActions    AdminAuditLog[]
  emailTokens     EmailVerificationToken[]
  apiCredentials  UserApiCredential[]
}

model UserApiCredential {
  id              String                @id @default(cuid())
  userId          String
  provider        ApiCredentialProvider @default(OPENAI_COMPATIBLE)
  name            String
  baseUrl         String
  modelName       String
  wireApi         String                @default("chat")
  encryptedApiKey String
  apiKeyLast4     String
  isEnabled       Boolean               @default(true)
  lastUsedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs            GenerationJob[]

  @@index([userId, isEnabled])
  @@index([provider])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Game {
  id                   String          @id @default(cuid())
  title                String
  slug                 String          @unique
  description          String
  coverUrl             String?
  tags                 String[]
  status               GameStatus      @default(DRAFT)
  manifestUrl          String?
  bundleUrl            String?
  storagePrefix        String?
  playCount            Int             @default(0)
  likeCount            Int             @default(0)
  favoriteCount        Int             @default(0)
  searchText           String?
  currentVersionNumber Int             @default(1)
  authorId             String
  createdByJobId       String?         @unique
  parentGameId         String?
  sourceVersionId      String?
  publishedAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  author               User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdByJob         GenerationJob?  @relation("GeneratedGame", fields: [createdByJobId], references: [id])
  parentGame           Game?           @relation("GameRemixes", fields: [parentGameId], references: [id], onDelete: SetNull)
  remixes              Game[]          @relation("GameRemixes")
  sourceVersion        GameVersion?    @relation("VersionRemixes", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  versions             GameVersion[]
  remixJobs            GenerationJob[] @relation("RemixJobs")
  events               GameEvent[]
  likes                GameLike[]
  favorites            GameFavorite[]
  reports              GameReport[]

  @@index([authorId])
  @@index([parentGameId])
  @@index([status, publishedAt])
  @@index([status, playCount])
  @@index([status, likeCount])
}

model OAuthAccount {
  id                String   @id @default(cuid())
  provider          String
  providerAccountId String
  email             String?
  userId            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}

model GameLike {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
}

model GameFavorite {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
}

model GenerationJob {
  id                   String              @id @default(cuid())
  prompt               String
  status               GenerationJobStatus @default(PENDING)
  progress             Int                 @default(0)
  error                String?
  inputFiles           Json?
  result               Json?
  moderationStatus     ModerationStatus    @default(PENDING)
  moderationReport     Json?
  estimatedCostCents   Int                 @default(0)
  modelInputTokens     Int                 @default(0)
  modelOutputTokens    Int                 @default(0)
  apiCredentialSource  ApiCredentialSource @default(PLATFORM)
  apiCredentialId      String?
  userId               String
  parentGameId         String?
  remixSourceVersionId String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  startedAt            DateTime?
  finishedAt           DateTime?
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiCredential        UserApiCredential?  @relation(fields: [apiCredentialId], references: [id], onDelete: SetNull)
  parentGame           Game?               @relation("RemixJobs", fields: [parentGameId], references: [id], onDelete: SetNull)
  remixSourceVersion   GameVersion?        @relation("RemixSourceJobs", fields: [remixSourceVersionId], references: [id], onDelete: SetNull)
  logs                 AgentLog[]
  artifacts            JobArtifact[]
  uploads              UploadedAsset[]
  game                 Game?               @relation("GeneratedGame")
  versions             GameVersion[]       @relation("JobVersions")

  @@index([userId])
  @@index([apiCredentialId])
  @@index([parentGameId])
  @@index([status, createdAt])
}

model JobArtifact {
  id         String        @id @default(cuid())
  jobId      String
  type       String
  version    Int           @default(1)
  payload    Json?
  storageKey String?
  publicUrl  String?
  sha256     String?
  createdAt  DateTime      @default(now())
  job        GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, type, version])
  @@index([jobId, type])
  @@index([type, createdAt])
}

model GameVersion {
  id            String          @id @default(cuid())
  gameId        String
  versionNumber Int
  title         String
  description   String
  manifestUrl   String
  bundleUrl     String
  coverUrl      String?
  storagePrefix String
  jobId         String?
  changeSummary String
  createdAt     DateTime        @default(now())
  game          Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  job           GenerationJob?  @relation("JobVersions", fields: [jobId], references: [id], onDelete: SetNull)
  remixedGames  Game[]          @relation("VersionRemixes")
  remixJobs     GenerationJob[] @relation("RemixSourceJobs")

  @@unique([gameId, versionNumber])
  @@index([jobId])
  @@index([createdAt])
}

model AgentLog {
  id        String        @id @default(cuid())
  jobId     String
  agentName String
  step      String
  message   String
  metadata  Json?
  createdAt DateTime      @default(now())
  job       GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model UploadedAsset {
  id          String            @id @default(cuid())
  ownerId     String
  jobId       String?
  kind        UploadedAssetKind @default(OTHER)
  filename    String
  contentType String
  sizeBytes   Int
  storageKey  String
  publicUrl   String
  createdAt   DateTime          @default(now())
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  job         GenerationJob?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([jobId])
}

model GameEvent {
  id        String        @id @default(cuid())
  gameId    String
  userId    String?
  type      GameEventType
  metadata  Json?
  createdAt DateTime      @default(now())
  game      Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gameId, createdAt])
  @@index([userId])
}

model GameReport {
  id         String           @id @default(cuid())
  gameId     String
  reporterId String?
  reason     String
  details    String?
  status     GameReportStatus @default(OPEN)
  createdAt  DateTime         @default(now())
  resolvedAt DateTime?
  resolverId String?
  game       Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  reporter   User?            @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: SetNull)
  resolver   User?            @relation("ResolverReports", fields: [resolverId], references: [id], onDelete: SetNull)

  @@index([gameId, status])
  @@index([reporterId])
  @@index([status, createdAt])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}
