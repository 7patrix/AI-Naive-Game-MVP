# App
APP_URL="http://localhost:3000"
AUTH_COOKIE_NAME="ai_arcade_session"
AUTH_SECRET="replace-with-a-long-random-secret"

# Database
DATABASE_URL="postgresql://arcade:arcade_password@localhost:5432/ai_arcade?schema=public"

# Object storage - local MinIO defaults
S3_ENDPOINT="http://localhost:9000"
S3_INTERNAL_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="ai-arcade"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL="http://localhost:9000/ai-arcade"

# Optional model provider. The MVP can run without this by using the fallback generator.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
MODEL_NAME="gpt-5.5"
# chat = /chat/completions, responses = /responses
MODEL_WIRE_API="chat"

# Optional outbound proxy for server-side OAuth/model requests.
# Example: OUTBOUND_PROXY_URL="http://127.0.0.1:7897"
OUTBOUND_PROXY_URL=""

# Optional GitHub OAuth. Email login works without these values.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:3000/api/auth/github/callback"

# Optional Google OAuth. Uses the same OAuthAccount table with provider="google".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
