# App
APP_URL="http://localhost:3000"
AUTH_COOKIE_NAME="ai_arcade_session"
AUTH_SECRET="replace-with-a-long-random-secret"

# Database
DATABASE_URL="postgresql://arcade:arcade_password@localhost:5432/ai_arcade?schema=public"

# Object storage - local MinIO defaults
S3_ENDPOINT="http://localhost:9000"
S3_INTERNAL_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="ai-arcade"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL="http://localhost:9000/ai-arcade"

# Optional model provider. The MVP can run without this by using the fallback generator.
OPENAI_API_KEY=""
MODEL_NAME="gpt-5.5"
